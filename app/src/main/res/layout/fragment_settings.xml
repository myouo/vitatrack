<?xml version="1.0" encoding="utf-8"?>
<ScrollView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Heart Rate Thresholds -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hr_thresholds"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- HR High -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/hr_high_threshold" />

                <TextView
                    android:id="@+id/tv_hr_high_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="150 BPM" />

                <SeekBar
                    android:id="@+id/seekbar_hr_high"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="200"
                    android:progress="150" />

                <!-- HR Low -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/hr_low_threshold" />

                <TextView
                    android:id="@+id/tv_hr_low_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="40 BPM" />

                <SeekBar
                    android:id="@+id/seekbar_hr_low"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="80"
                    android:progress="20" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step Frequency Thresholds -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/step_freq_thresholds"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Step Freq High -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/step_freq_high_threshold" />

                <TextView
                    android:id="@+id/tv_step_freq_high_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3.0 Hz" />

                <SeekBar
                    android:id="@+id/seekbar_step_freq_high"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="50"
                    android:progress="30" />

                <!-- Step Freq Low -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/step_freq_low_threshold" />

                <TextView
                    android:id="@+id/tv_step_freq_low_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.5 Hz" />

                <SeekBar
                    android:id="@+id/seekbar_step_freq_low"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="20"
                    android:progress="5" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Fall Detection -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/fall_detection"
                    android:textSize="16sp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_fall_detection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Export -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/data_export"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_export"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/export_csv"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <ProgressBar
                    android:id="@+id/progress_export"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
