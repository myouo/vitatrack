<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="?attr/cardBackgroundColor"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- Severity Badge -->
            <TextView
                android:id="@+id/tv_severity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="高"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_severity_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:layout_marginEnd="12dp" />

            <!-- Timestamp -->
            <TextView
                android:id="@+id/tv_timestamp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2024-01-01 12:00:00"
                android:textSize="12sp"
                android:textColor="?attr/textSecondaryColor" />

            <!-- Acknowledged Indicator -->
            <ImageView
                android:id="@+id/iv_acknowledged"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_check"
                android:visibility="gone"
                android:tint="@color/status_success"
                android:contentDescription="@string/acknowledged" />
        </LinearLayout>

        <!-- Event Type -->
        <TextView
            android:id="@+id/tv_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="心率异常"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?attr/textPrimaryColor"
            android:layout_marginBottom="8dp" />

        <!-- Details -->
        <TextView
            android:id="@+id/tv_details"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="检测到心率异常升高，当前心率 145 BPM"
            android:textSize="14sp"
            android:textColor="?attr/textSecondaryColor"
            android:maxLines="3"
            android:ellipsize="end"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
